<script>
  gsap.registerPlugin(ScrollTrigger);

  // Nav scroll state
  const navbar = document.getElementById('navbar');
  window.addEventListener('scroll', () => {
    navbar.classList.toggle('scrolled', window.scrollY > 40);
  }, { passive: true });

  // Hero entrance animation
  gsap.fromTo('.hero-text',
    { opacity: 0, y: 40 },
    { opacity: 1, y: 0, duration: 1.1, ease: 'power3.out', delay: 0.3 }
  );

  // Product cards stagger reveal
  gsap.to('.product-card', {
    opacity: 1,
    y: 0,
    duration: 0.7,
    ease: 'power3.out',
    stagger: 0.12,
    scrollTrigger: {
      trigger: '#products',
      start: 'top 80%',
      once: true,
    }
  });

  // Whey cards stagger
  gsap.to('.whey-grid .product-card', {
    opacity: 1,
    y: 0,
    duration: 0.7,
    ease: 'power3.out',
    stagger: 0.12,
    scrollTrigger: {
      trigger: '.whey-grid',
      start: 'top 80%',
      once: true,
    }
  });

  // Subheader reveal
  gsap.from('.products-subheader', {
    opacity: 0,
    y: 24,
    duration: 0.7,
    ease: 'power3.out',
    scrollTrigger: {
      trigger: '.products-subheader',
      start: 'top 85%',
      once: true,
    }
  });

  // Products header reveal
  gsap.from('.products-header', {
    opacity: 0,
    y: 30,
    duration: 0.8,
    ease: 'power3.out',
    scrollTrigger: {
      trigger: '#products',
      start: 'top 85%',
      once: true,
    }
  });

  // -- FEATURE CAROUSEL -------------------------
  const FC_FEATURES = [
    { id:'quality',       label:'Premium Quality Health Supplements', image:'https://images.unsplash.com/photo-1526506118085-60ce8714f8c5?w=700&q=85&fit=crop', desc:'Perfect ratio of every ingredient in all our products to ensure maximum benefits.' },
    { id:'macro',         label:'Macronutrients & Micronutrients',    image:'https://images.unsplash.com/photo-1490645935967-10de6ba17061?w=700&q=85&fit=crop', desc:'We not only focus on fulfilling macronutrient requirements but micronutrients as well.' },
    { id:'constituents',  label:"Our Supplements' Constituents",      image:'https://images.unsplash.com/photo-1532187863486-abf9dbad1b69?w=700&q=85&fit=crop', desc:'Iron Pump Nutrition is crafted from carefully chosen, premium ingredients and expert guidance.' },
    { id:'transparent',   label:'Transparent & Trustworthy',          image:'https://images.unsplash.com/photo-1454165804606-c3d57bc86b40?w=700&q=85&fit=crop', desc:'Test Certificates from FSSAI-Approved labs to evidence our claims on Nutritional Profiling.' },
  ];

  const FC_ICONS = {
    quality:      '<polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>',
    macro:        '<path d="M18 8h1a4 4 0 0 1 0 8h-1"/><path d="M2 8h16v9a4 4 0 0 1-4 4H6a4 4 0 0 1-4-4V8z"/><line x1="6" y1="1" x2="6" y2="4"/><line x1="10" y1="1" x2="10" y2="4"/><line x1="14" y1="1" x2="14" y2="4"/>',
    constituents: '<circle cx="12" cy="12" r="3"/><path d="M12 1v4M12 19v4M4.22 4.22l2.83 2.83M16.95 16.95l2.83 2.83M1 12h4M19 12h4M4.22 19.78l2.83-2.83M16.95 7.05l2.83-2.83"/>',
    transparent:  '<path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/>',
  };

  const FC_ITEM_H = 65;
  let fc_cur = 0;
  let fc_paused = false;
  let fc_timer;

  function fc_wrapDiff(diff, total) {
    const half = total / 2;
    while (diff > half)  diff -= total;
    while (diff < -half) diff += total;
    return diff;
  }

  // Build chips
  const drumEl = document.getElementById('chips-drum');
  FC_FEATURES.forEach((f, i) => {
    const chip = document.createElement('button');
    chip.className = 'feature-chip';
    chip.dataset.index = i;
    chip.innerHTML = `
      <span class="chip-icon">
        <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">${FC_ICONS[f.id]}</svg>
      </span>
      <span class="chip-label">${f.label}</span>`;
    chip.addEventListener('click', () => { fc_goTo(i); fc_startAuto(); });
    chip.addEventListener('mouseenter', () => { fc_paused = true; });
    chip.addEventListener('mouseleave', () => { fc_paused = false; });
    drumEl.appendChild(chip);
  });

  // Build cards
  const stackEl = document.getElementById('cards-stack');
  FC_FEATURES.forEach((f, i) => {
    const card = document.createElement('div');
    card.className = 'feature-card card-inactive';
    card.innerHTML = `
      <img src="${f.image}" alt="${f.label}" />
      <div class="card-live" style="opacity:0">
        <div class="card-live-dot"></div>
        <span class="card-live-text">Active</span>
      </div>
      <div class="card-overlay" style="opacity:0;transform:translateY(15px)">
        <div class="card-badge">${String(i+1).padStart(2,'0')} · ${f.label}</div>
        <p class="card-desc">${f.desc}</p>
      </div>`;
    stackEl.appendChild(card);
  });

  function fc_updateChips() {
    document.querySelectorAll('.feature-chip').forEach((chip, i) => {
      const diff = fc_wrapDiff(i - fc_cur, FC_FEATURES.length);
      const isActive = diff === 0;
      gsap.to(chip, {
        y: diff * FC_ITEM_H,
        opacity: Math.max(0, 1 - Math.abs(diff) * 0.25),
        duration: 0.55,
        ease: 'power3.out'
      });
      chip.classList.toggle('chip-active', isActive);
    });
  }

  function fc_updateCards() {
    document.querySelectorAll('.feature-card').forEach((card, i) => {
      const total = FC_FEATURES.length;
      let diff = i - fc_cur;
      if (diff > total/2)  diff -= total;
      if (diff < -total/2) diff += total;
      const isActive = diff === 0;
      const isPrev   = diff === -1;
      const isNext   = diff === 1;

      gsap.to(card, {
        x:        isActive ? 0 : isPrev ? -110 : isNext ? 110 : 0,
        scale:    isActive ? 1 : (isPrev || isNext) ? 0.85 : 0.7,
        opacity:  isActive ? 1 : (isPrev || isNext) ? 0.4 : 0,
        rotation: isPrev ? -4 : isNext ? 4 : 0,
        zIndex:   isActive ? 20 : (isPrev || isNext) ? 10 : 0,
        duration: 0.55,
        ease: 'power3.out'
      });

      card.classList.toggle('card-inactive', !isActive);

      const overlay = card.querySelector('.card-overlay');
      const live    = card.querySelector('.card-live');
      gsap.to(overlay, { opacity: isActive ? 1 : 0, y: isActive ? 0 : 15, duration: 0.35, ease: 'power2.out', delay: isActive ? 0.12 : 0 });
      gsap.to(live,    { opacity: isActive ? 1 : 0, y: isActive ? 0 : 8,  duration: 0.3,  ease: 'power2.out', delay: isActive ? 0.15 : 0 });
    });
  }

  function fc_goTo(index) {
    fc_cur = ((index % FC_FEATURES.length) + FC_FEATURES.length) % FC_FEATURES.length;
    fc_updateChips();
    fc_updateCards();
  }

  function fc_startAuto() {
    clearInterval(fc_timer);
    fc_timer = setInterval(() => { if (!fc_paused) fc_goTo(fc_cur + 1); }, 3000);
  }

  // Scroll-triggered init
  ScrollTrigger.create({
    trigger: '#why-ipn',
    start: 'top 75%',
    once: true,
    onEnter: () => {
      fc_updateChips();
      fc_updateCards();
      fc_startAuto();
      gsap.from('.why-inner', { opacity: 0, y: 40, duration: 0.8, ease: 'power3.out' });
    }
  });

  gsap.from('.why-header', {
    opacity: 0, y: 28, duration: 0.8, ease: 'power3.out',
    scrollTrigger: { trigger: '#why-ipn', start: 'top 85%', once: true }
  });
</script>

</body>
</html>
