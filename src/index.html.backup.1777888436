<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Iron Pump Nutrition — Unleash The Beast</title>

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Oswald:wght@400;600;700&display=swap" rel="stylesheet" />

  <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js"></script>

  <style>
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

    html, body {
      width: 100%;
      background: #000;
    }

    body {
      overflow-x: hidden;
    }

    /* -- HERO --------------------------------------- */
    #hero {
      position: relative;
      width: 100vw; height: 100vh;
      overflow: hidden;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: flex-end;
    }

    /* -- HERO VIDEO --------------------------------- */
    #hero-video {
      position: absolute;
      inset: 0;
      width: 100%; height: 100%;
      object-fit: cover;
      object-position: center center;
      display: block;
      z-index: 0;
    }

    /* Overlay */
    #overlay {
      position: absolute;
      inset: 0;
      z-index: 1;
      pointer-events: none;
      background: linear-gradient(
        to bottom,
        rgba(0,0,0,0.45) 0%,
        rgba(0,0,0,0.10) 30%,
        rgba(0,0,0,0.30) 70%,
        rgba(0,0,0,0.85) 100%
      );
    }

    /* -- HERO CONTENT ------------------------------- */
    .hero-content {
      position: absolute;
      inset: 0;
      z-index: 10;
      display: flex;
      align-items: flex-end;
      padding: 0 80px 100px;
    }

    .hero-text {
      max-width: 680px;
      will-change: transform, opacity;
    }

    .hero-eyebrow {
      display: block;
      font-family: 'Oswald', sans-serif;
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 0.45em;
      text-transform: uppercase;
      color: #FFB800;
      margin-bottom: 16px;
    }

    .hero-headline {
      font-family: 'Bebas Neue', sans-serif;
      font-size: clamp(72px, 10vw, 130px);
      line-height: 0.88;
      letter-spacing: 0.03em;
      color: #fff;
      margin-bottom: 24px;
      text-shadow: 0 4px 40px rgba(0,0,0,0.5);
    }

    .hero-sub {
      font-family: 'Oswald', sans-serif;
      font-size: 16px;
      font-weight: 400;
      letter-spacing: 0.06em;
      color: rgba(255,255,255,0.65);
      line-height: 1.6;
      max-width: 460px;
      margin-bottom: 40px;
      text-transform: uppercase;
    }

    .hero-ctas {
      display: flex;
      gap: 14px;
      align-items: center;
      flex-wrap: wrap;
    }

    .btn-primary {
      font-family: 'Oswald', sans-serif;
      font-weight: 700;
      font-size: 13px;
      letter-spacing: 0.35em;
      text-transform: uppercase;
      text-decoration: none;
      color: #000;
      background: #FFB800;
      padding: 15px 44px;
      display: inline-flex; align-items: center; gap: 8px;
      transition: background 220ms, transform 180ms;
      will-change: transform;
    }

    .btn-primary:hover {
      background: #ffc933;
      transform: translateY(-1px);
    }

    .btn-ghost {
      font-family: 'Oswald', sans-serif;
      font-weight: 700;
      font-size: 13px;
      letter-spacing: 0.35em;
      text-transform: uppercase;
      text-decoration: none;
      color: rgba(255,255,255,0.8);
      background: transparent;
      border: 1px solid rgba(255,255,255,0.25);
      padding: 14px 44px;
      display: inline-flex; align-items: center;
      transition: border-color 220ms, color 220ms, transform 180ms;
      will-change: transform;
    }

    .btn-ghost:hover {
      border-color: #FFB800;
      color: #FFB800;
      transform: translateY(-1px);
    }

    @media (max-width: 768px) {
      .hero-content { padding: 0 28px 120px; align-items: flex-end; }
      .hero-sub { font-size: 13px; }
    }

    /* -- MARQUEE STRIP ------------------------------ */
    #marquee-strip {
      background: #FFB800;
      overflow: hidden;
      height: 44px;
      display: flex;
      align-items: center;
      position: relative;
      z-index: 2;
    }

    .marquee-track {
      display: flex;
      align-items: center;
      white-space: nowrap;
      animation: marquee-scroll 28s linear infinite;
      will-change: transform;
    }

    .marquee-track:hover { animation-play-state: paused; }

    @keyframes marquee-scroll {
      from { transform: translateX(0); }
      to   { transform: translateX(-50%); }
    }

    .marquee-item {
      font-family: 'Oswald', sans-serif;
      font-size: 12px;
      font-weight: 700;
      letter-spacing: 0.3em;
      text-transform: uppercase;
      color: #000;
      padding: 0 32px;
      display: flex;
      align-items: center;
      gap: 32px;
      flex-shrink: 0;
    }

    .marquee-sep {
      width: 4px; height: 4px;
      border-radius: 50%;
      background: rgba(0,0,0,0.35);
      flex-shrink: 0;
    }

    /* -- NAV ---------------------------------------- */
    #navbar {
      position: absolute;
      top: 0; left: 0; right: 0;
      z-index: 20;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0 36px;
      height: 70px;
      background: rgba(0,0,0,0.62);
      backdrop-filter: blur(6px);
      border-bottom: 1px solid rgba(255,255,255,0.06);
    }

    .nav-socials {
      display: flex; gap: 14px; align-items: center; min-width: 60px;
    }
    .nav-socials a {
      display: flex; align-items: center;
      opacity: 0.7; transition: opacity 180ms; cursor: pointer;
    }
    .nav-socials a:hover { opacity: 1; }
    .nav-socials svg { width: 16px; height: 16px; fill: #fff; }

    .nav-center {
      display: flex; align-items: center; gap: 40px;
      flex: 1; justify-content: center;
    }

    .nav-links {
      display: flex; gap: 36px; list-style: none; align-items: center;
    }

    .nav-link {
      font-family: 'Oswald', sans-serif;
      font-weight: 700; font-size: 12.5px;
      letter-spacing: 0.22em;
      color: rgba(255,255,255,0.85);
      text-decoration: none; text-transform: uppercase;
      cursor: pointer; transition: color 160ms ease;
    }
    .nav-link:hover { color: #FFB800; }

    #nav-logo { cursor: pointer; display: flex; align-items: center; }
    #nav-logo img {
      height: 52px; width: auto;
      filter: brightness(0) invert(1) drop-shadow(0 0 18px rgba(255,255,255,0.15));
      object-fit: contain;
    }

    /* nav scrolled state */
    #navbar.scrolled {
      background: rgba(0,0,0,0.88);
      border-bottom-color: rgba(255,255,255,0.1);
    }

    /* -- WHY IPN SECTION ----------------------- */
    #why-ipn {
      background: #050505;
      padding: 100px 40px;
      position: relative;
    }

    #why-ipn::before {
      content: '';
      position: absolute;
      top: 0; left: 0; right: 0;
      height: 1px;
      background: linear-gradient(to right, transparent, rgba(255,184,0,0.4), transparent);
    }

    .why-header {
      text-align: center;
      margin-bottom: 60px;
    }

    .why-inner {
      max-width: 1280px;
      margin: 0 auto;
      display: flex;
      border-radius: 32px;
      overflow: hidden;
      min-height: 680px;
      border: 1px solid rgba(255,255,255,0.06);
    }

    /* Left panel — chip drum */
    .why-left {
      width: 40%;
      position: relative;
      background: #0f0f0f;
      display: flex;
      align-items: center;
      justify-content: flex-start;
      overflow: hidden;
      padding: 0 40px;
    }

    .why-left::before,
    .why-left::after {
      content: '';
      position: absolute;
      left: 0; right: 0;
      height: 130px;
      z-index: 10;
      pointer-events: none;
    }
    .why-left::before {
      top: 0;
      background: linear-gradient(to bottom, #0f0f0f 0%, transparent 100%);
    }
    .why-left::after {
      bottom: 0;
      background: linear-gradient(to top, #0f0f0f 0%, transparent 100%);
    }

    .chips-drum {
      position: relative;
      width: 100%;
      height: 100%;
      display: flex;
      align-items: center;
    }

    .feature-chip {
      position: absolute;
      left: 0;
      display: flex;
      align-items: center;
      gap: 14px;
      padding: 14px 24px;
      border-radius: 100px;
      border: 1px solid rgba(255,255,255,0.1);
      background: transparent;
      cursor: pointer;
      white-space: nowrap;
      will-change: transform, opacity;
      transition: border-color 250ms;
    }

    .chip-icon {
      width: 18px; height: 18px;
      flex-shrink: 0;
      display: flex; align-items: center; justify-content: center;
      color: rgba(255,255,255,0.4);
      transition: color 250ms;
    }

    .chip-label {
      font-family: 'Oswald', sans-serif;
      font-size: 13px;
      font-weight: 600;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.4);
      transition: color 250ms;
    }

    .feature-chip.chip-active {
      background: #FFB800;
      border-color: #FFB800;
    }
    .feature-chip.chip-active .chip-label { color: #000; }
    .feature-chip.chip-active .chip-icon { color: #000; }

    .feature-chip:not(.chip-active):hover {
      border-color: rgba(255,255,255,0.25);
    }
    .feature-chip:not(.chip-active):hover .chip-label { color: rgba(255,255,255,0.7); }
    .feature-chip:not(.chip-active):hover .chip-icon { color: rgba(255,255,255,0.7); }

    /* Right panel — card stack */
    .why-right {
      flex: 1;
      background: #0a0a0a;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 60px 40px;
      border-left: 1px solid rgba(255,255,255,0.05);
    }

    .cards-stack {
      position: relative;
      width: 360px;
      aspect-ratio: 4/5;
    }

    .feature-card {
      position: absolute;
      inset: 0;
      border-radius: 24px;
      overflow: hidden;
      border: 4px solid #000;
      background: #111;
      will-change: transform, opacity;
      transform-origin: center center;
    }

    .feature-card img {
      width: 100%; height: 100%;
      object-fit: cover;
      object-position: center center;
      display: block;
      transition: filter 500ms ease;
    }

    .feature-card.card-inactive img {
      filter: grayscale(1) blur(2px) brightness(0.7);
    }

    .card-overlay {
      position: absolute;
      inset-x: 0; bottom: 0;
      padding: 40px 20px 22px;
      background: linear-gradient(to top, rgba(0,0,0,0.92) 0%, rgba(0,0,0,0.4) 60%, transparent 100%);
      pointer-events: none;
      will-change: transform, opacity;
    }

    .card-badge {
      display: inline-block;
      background: #000;
      color: rgba(255,255,255,0.85);
      border: 1px solid rgba(255,255,255,0.15);
      padding: 4px 12px;
      border-radius: 100px;
      font-family: 'Oswald', sans-serif;
      font-size: 10px;
      letter-spacing: 0.25em;
      text-transform: uppercase;
      margin-bottom: 8px;
    }

    .card-desc {
      font-family: 'Oswald', sans-serif;
      font-size: 16px;
      font-weight: 400;
      color: #fff;
      line-height: 1.35;
      letter-spacing: 0.02em;
    }

    .card-live {
      position: absolute;
      top: 18px; left: 18px;
      display: flex;
      align-items: center;
      gap: 8px;
      pointer-events: none;
      will-change: transform, opacity;
    }

    .card-live-dot {
      width: 7px; height: 7px;
      border-radius: 50%;
      background: #FFB800;
      box-shadow: 0 0 8px #FFB800, 0 0 16px rgba(255,184,0,0.4);
    }

    .card-live-text {
      font-family: 'Oswald', sans-serif;
      font-size: 10px;
      letter-spacing: 0.3em;
      color: rgba(255,255,255,0.65);
      text-transform: uppercase;
    }

    /* Trust badges */
    .trust-badges {
      max-width: 1280px;
      margin: 48px auto 0;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 0;
      border: 1px solid rgba(255,255,255,0.07);
      border-radius: 16px;
      overflow: hidden;
    }

    .trust-badge {
      flex: 1;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 12px;
      padding: 24px 20px;
      background: #0f0f0f;
      transition: background 250ms;
    }

    .trust-badge:hover { background: #161616; }

    .trust-icon {
      flex-shrink: 0;
      width: 36px; height: 36px;
      background: rgba(255,184,0,0.08);
      border-radius: 8px;
      display: flex; align-items: center; justify-content: center;
    }

    .trust-badge span {
      font-family: 'Oswald', sans-serif;
      font-size: 13px;
      font-weight: 600;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.75);
    }

    .trust-sep {
      width: 1px;
      height: 60px;
      background: rgba(255,255,255,0.07);
      flex-shrink: 0;
    }

    @media (max-width: 768px) {
      .trust-badges { flex-wrap: wrap; border-radius: 12px; }
      .trust-badge { flex: 0 0 50%; border-bottom: 1px solid rgba(255,255,255,0.07); }
      .trust-sep { display: none; }
    }

    @media (max-width: 900px) {
      .why-inner { flex-direction: column; }
      .why-left { width: 100%; min-height: 320px; padding: 40px; justify-content: center; }
      .why-right { padding: 40px 20px; }
      .cards-stack { width: 260px; }
    }
    @media (max-width: 600px) {
      #why-ipn { padding: 70px 20px; }
      .why-inner { border-radius: 20px; }
    }

    /* -- FOOTER -------------------------------- */
    footer {
      background: #050505;
      border-top: 1px solid rgba(255,255,255,0.06);
    }

    .footer-inner {
      max-width: 1280px;
      margin: 0 auto;
      padding: 80px 40px 0;
    }

    .footer-top {
      display: flex;
      gap: 80px;
      padding-bottom: 60px;
    }

    /* Brand column */
    .footer-brand {
      flex: 0 0 300px;
      display: flex;
      flex-direction: column;
      gap: 20px;
    }

    .footer-logo {
      display: flex;
      align-items: center;
      gap: 12px;
      text-decoration: none;
    }

    .footer-logo img {
      height: 40px;
      width: auto;
      mix-blend-mode: screen;
    }

    .footer-logo span {
      font-family: 'Oswald', sans-serif;
      font-size: 16px;
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: #fff;
    }

    .footer-desc {
      font-family: 'Oswald', sans-serif;
      font-size: 13px;
      font-weight: 400;
      letter-spacing: 0.04em;
      color: rgba(255,255,255,0.4);
      line-height: 1.6;
      max-width: 260px;
    }

    .footer-socials {
      display: flex;
      gap: 16px;
      list-style: none;
    }

    .footer-socials a {
      width: 38px; height: 38px;
      border: 1px solid rgba(255,255,255,0.1);
      border-radius: 8px;
      display: flex; align-items: center; justify-content: center;
      color: rgba(255,255,255,0.5);
      transition: border-color 220ms, color 220ms, background 220ms;
    }

    .footer-socials a:hover {
      border-color: #FFB800;
      color: #FFB800;
      background: rgba(255,184,0,0.08);
    }

    .footer-socials svg { width: 16px; height: 16px; }

    /* Links grid */
    .footer-links-grid {
      flex: 1;
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 40px;
    }

    .footer-col h4 {
      font-family: 'Oswald', sans-serif;
      font-size: 13px;
      font-weight: 700;
      letter-spacing: 0.25em;
      text-transform: uppercase;
      color: #fff;
      margin-bottom: 20px;
    }

    .footer-col ul { list-style: none; display: flex; flex-direction: column; gap: 12px; }

    .footer-col a {
      font-family: 'Oswald', sans-serif;
      font-size: 13px;
      font-weight: 400;
      letter-spacing: 0.08em;
      color: rgba(255,255,255,0.4);
      text-decoration: none;
      text-transform: uppercase;
      transition: color 180ms;
    }

    .footer-col a:hover { color: #FFB800; }

    /* Bottom bar */
    .footer-bottom {
      border-top: 1px solid rgba(255,255,255,0.06);
      padding: 24px 0 28px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 20px;
    }

    .footer-copy {
      font-family: 'Oswald', sans-serif;
      font-size: 11px;
      letter-spacing: 0.18em;
      color: rgba(255,255,255,0.3);
      text-transform: uppercase;
    }

    .footer-legal {
      display: flex;
      gap: 24px;
      list-style: none;
    }

    .footer-legal a {
      font-family: 'Oswald', sans-serif;
      font-size: 11px;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.3);
      text-decoration: none;
      transition: color 180ms;
    }

    .footer-legal a:hover { color: rgba(255,255,255,0.7); }

    @media (max-width: 900px) {
      .footer-top { flex-direction: column; gap: 40px; }
      .footer-brand { flex: none; }
      .footer-desc { max-width: 100%; }
    }

    @media (max-width: 600px) {
      .footer-inner { padding: 60px 20px 0; }
      .footer-links-grid { grid-template-columns: repeat(2, 1fr); gap: 30px; }
      .footer-bottom { flex-direction: column; align-items: flex-start; }
    }

    @media (prefers-reduced-motion: reduce) {
      * { transition-duration: 0.01ms !important; animation-duration: 0.01ms !important; }
    }

    /* -- PRODUCTS SECTION ----------------------- */
    #products {
      background: #080808;
      padding: 100px 40px;
      position: relative;
    }

    #products::before {
      content: '';
      position: absolute;
      top: 0; left: 0; right: 0;
      height: 1px;
      background: linear-gradient(to right, transparent, rgba(255,184,0,0.4), transparent);
    }

    .products-header {
      text-align: center;
      margin-bottom: 70px;
    }

    .products-label {
      font-family: 'Oswald', sans-serif;
      font-size: 11px;
      letter-spacing: 0.45em;
      color: #FFB800;
      text-transform: uppercase;
      margin-bottom: 12px;
      display: block;
    }

    .products-title {
      font-family: 'Bebas Neue', sans-serif;
      font-size: clamp(48px, 7vw, 88px);
      color: #fff;
      line-height: 0.9;
      letter-spacing: 0.04em;
    }

    .products-title span {
      color: #FFB800;
    }

    /* Sub-header */
    .products-subheader {
      text-align: center;
      margin-bottom: 50px;
      padding-top: 20px;
      position: relative;
    }

    .products-subheader::before {
      content: '';
      position: absolute;
      top: 0; left: 50%;
      transform: translateX(-50%);
      width: 80px; height: 1px;
      background: rgba(255,184,0,0.35);
    }

    .products-subtitle {
      font-family: 'Bebas Neue', sans-serif;
      font-size: clamp(36px, 5vw, 64px);
      color: #fff;
      letter-spacing: 0.04em;
      line-height: 1;
      margin-bottom: 10px;
    }

    .products-subtitle span { color: #FFB800; }

    .products-sub-desc {
      font-family: 'Oswald', sans-serif;
      font-size: 11px;
      letter-spacing: 0.25em;
      color: rgba(255,255,255,0.35);
      text-transform: uppercase;
    }

    .whey-grid { margin-top: 0; }

    /* Grid */
    .products-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 20px;
      max-width: 1280px;
      margin: 0 auto;
    }

    @media (max-width: 1100px) {
      .products-grid { grid-template-columns: repeat(2, 1fr); }
    }
    @media (max-width: 600px) {
      .products-grid { grid-template-columns: 1fr; }
      #products { padding: 70px 20px; }
    }

    /* Card */
    .product-card {
      background: #0f0f0f;
      border: 1px solid rgba(255,255,255,0.07);
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: center;
      padding: 28px 20px 24px;
      position: relative;
      overflow: hidden;
      cursor: pointer;
      will-change: transform;
      transition: border-color 280ms ease, box-shadow 280ms ease;
      opacity: 0;
      transform: translateY(32px);
    }

    .product-card::after {
      content: '';
      position: absolute;
      bottom: 0; left: 0; right: 0;
      height: 2px;
      background: #FFB800;
      transform: scaleX(0);
      transform-origin: left;
      transition: transform 320ms ease;
    }

    .product-card:hover {
      border-color: rgba(255,184,0,0.25);
      box-shadow: 0 16px 48px rgba(0,0,0,0.6), 0 0 0 1px rgba(255,184,0,0.08);
    }

    .product-card:hover::after {
      transform: scaleX(1);
    }

    /* Image */
    .card-img {
      width: 100%;
      height: 260px;
      display: flex;
      align-items: center;
      justify-content: center;
      margin-bottom: 20px;
      overflow: hidden;
    }

    .card-img img {
      height: 100%;
      width: auto;
      max-width: 100%;
      object-fit: contain;
      transition: transform 360ms ease;
      will-change: transform;
    }

    .product-card:hover .card-img img {
      transform: scale(1.07) translateY(-4px);
    }

    /* Type badge */
    .card-type {
      font-family: 'Oswald', sans-serif;
      font-size: 10px;
      letter-spacing: 0.35em;
      color: rgba(255,255,255,0.4);
      text-transform: uppercase;
      margin-bottom: 6px;
    }

    /* Name */
    .card-name {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 26px;
      color: #fff;
      letter-spacing: 0.06em;
      line-height: 1.1;
      margin-bottom: 4px;
    }

    /* Flavour */
    .card-flavour {
      font-family: 'Oswald', sans-serif;
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 0.2em;
      color: #FFB800;
      text-transform: uppercase;
      margin-bottom: 20px;
    }

    /* Pricing */
    .card-pricing {
      margin-top: auto;
      width: 100%;
      border-top: 1px solid rgba(255,255,255,0.06);
      padding-top: 16px;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 8px;
    }

    .card-price {
      font-family: 'Oswald', sans-serif;
      font-size: 28px;
      font-weight: 700;
      color: #fff;
      letter-spacing: 0.02em;
    }

    .card-offer {
      display: flex;
      align-items: center;
      gap: 10px;
      background: rgba(255,184,0,0.08);
      border: 1px solid rgba(255,184,0,0.18);
      padding: 5px 14px;
      font-family: 'Oswald', sans-serif;
      font-size: 11px;
      letter-spacing: 0.08em;
    }

    .card-original {
      color: rgba(255,255,255,0.35);
      text-decoration: line-through;
    }

    .card-discount {
      color: #FFB800;
      font-weight: 700;
    }

    /* Shop button */
    .card-btn {
      margin-top: 16px;
      width: 100%;
      font-family: 'Oswald', sans-serif;
      font-weight: 700;
      font-size: 11px;
      letter-spacing: 0.35em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.7);
      background: transparent;
      border: 1px solid rgba(255,255,255,0.12);
      padding: 11px 0;
      cursor: pointer;
      transition: background 220ms, border-color 220ms, color 220ms;
    }

    .card-btn:hover {
      background: #FFB800;
      border-color: #FFB800;
      color: #000;
    }
  </style>
</head>
